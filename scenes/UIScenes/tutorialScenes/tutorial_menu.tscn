[node name="Description" type="RichTextLabel" parent="TutorialSlides/Player Actions/Control" unique_id=239860890]
layout_mode = 0
offset_left = 189.0
offset_top = 21.0
offset_right = 1044.0
offset_bottom = 906.0
theme_override_font_sizes/normal_font_size = 28
text = "
Each player has a colored marker:


A player may do up to 4 actions each turn:


Drive / Ferry
Move to an adjacent city by clicking on the node

Direct Flight
Double-click a city card in your hand to move to it's location, discarding the card in the process

Charter Flight
If the city card you've discarded matches the city you're in then you may move to ANY city node

Shuttle Flight
If you are in a city that has a research station then you may move to any other city that has a research station"
autowrap_mode = 2

[node name="Description2" type="RichTextLabel" parent="TutorialSlides/Player Actions/Control" unique_id=1944776250]
layout_mode = 0
offset_left = 1177.0
offset_top = 98.0
offset_right = 1789.0
offset_bottom = 978.0
theme_override_font_sizes/normal_font_size = 28
text = "Build a Research Station
(IN DEVELOPMENT) Builds a research station on the city you are in, only 6 can be built!

Treat Disease
Clicking the Removes 1 disease cube of the respective color from the city you are in.

- If the disease is \"cured\" and no other disease cube of its color is on the board then it is \"eradicated\" and will no longer spawn in

Share Knowledge
(IN DEVELOPMENT, Maybe?)



Discover Cure
At ANY research station you can \"cure\" a disease if you have 5 city cards of the same color in your hand"
autowrap_mode = 2

