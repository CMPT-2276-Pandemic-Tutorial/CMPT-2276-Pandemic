[node name="Description" type="RichTextLabel" parent="TutorialSlides/Tips/Control" unique_id=262337585]
layout_mode = 0
offset_left = 64.0
offset_top = 50.0
offset_right = 1663.0
offset_bottom = 935.0
theme_override_font_sizes/normal_font_size = 28
text = "- Each player should go to different areas on the board to manage the spread of disease

- Balance your actions between treating and curing disease

- Don't let the game drag on too long, once the infection rate gets higher the situation gets more desperate :(

- You can hover over many markers and icons on the board for descriptions and useful tips!

- Designate a player whose focus will be on curing diseases while the rest treat them

- Once an Epidemic card is drawn try to stay in areas where disease previously broke out as they will be hit soon by another wave of infections!

- Use city cards to quickly travel around the map!

- Spread out research stations across the map for convenient travel and disease curing!

- Have fun :)
"
autowrap_mode = 2

