text = "Infection Cards
X infection cards are drawn from the infection deck which will place a disease cube on the corresponding city














The amount of cards drawn  is based on the current infection rate "
autowrap_mode = 2

[node name="Description2" type="RichTextLabel" parent="TutorialSlides/Card Types/Control" unique_id=2081049220]
layout_mode = 0
offset_left = 1052.0
offset_top = 41.0
offset_right = 1504.0
offset_bottom = 921.0
theme_override_font_sizes/normal_font_size = 28
text = "Epidemic Cards
When drawn from the player deck it does 3 things:

1. Increases the infection rate by one space
2. Draws from the infection deck and puts 3 disease cubes on that city
3. Shuffles the cards in the infection discard pile and puts them on TOP of the infection deck



Event Cards
These are player cards that each have there own unique abilities! Hover over them to see what they do!"
autowrap_mode = 2

